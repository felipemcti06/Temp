OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Modelo padrão (opcional): openai/gpt-4o-mini ou anthropic/claude-sonnet-4-6
DEFAULT_MODEL_ID=openai/gpt-4o-mini

# Integração TM1
# Fase 1: list_cubes, list_dimensions, cube_summary, ping
# Fase 2: execute_mdx, search, search_in_rules, get_cube_rules, list_processes, list_elements
TM1_MCP_URL=https://tm1-ide-v2-production.up.railway.app
TM1_MCP_TOKEN=seu-token-aqui
TM1_CONNECTION_ID=uuid-da-conexao-tm1

# Autenticação (login/senha)
AUTH_USERNAME=admin
AUTH_PASSWORD=troque-esta-senha
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_SECRET_KEY=sua-chave-secreta-aqui

# CORS (opcional, separado por vírgula)
# CORS_ORIGINS=https://chat.flmiranda.work,http://localhost:5173

# Relatórios HTML (expiração em horas)
REPORT_TTL_HOURS=24

# Subagentes (Fase 1)
# Modelo para consultar TM1; modelo premium para gerar HTML
DATA_AGENT_MODEL=anthropic/claude-sonnet-4-6
# Se vazio, usa o modelo escolhido pelo usuário no seletor
# REPORT_AGENT_MODEL=anthropic/claude-opus-4-7
# ENABLE_REPORT_AGENTS=true

# Fast path (Fase 2): glossário + template Jinja2, sem LLM
# ENABLE_FAST_REPORT_PATH=true

