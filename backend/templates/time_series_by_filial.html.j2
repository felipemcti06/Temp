<header class="report-header">
  {% if logo_src %}
  <img class="report-logo" src="{{ logo_src }}" alt="{{ brand_name }}" />
  {% endif %}
  <div class="report-header__text">
    <p class="report-brand">{{ brand_name }} · Relatório Gerencial</p>
    <p class="report-meta">
      {{ metric }} · {{ period }} · Por filial · Versão {{ version }} · Gerado em {{ generated_at }}
    </p>
  </div>
</header>

<h1>{{ title }}</h1>

<section>
  <h2>Resumo executivo</h2>
  <p>{{ summary }}</p>
</section>

<section class="report-table-section">
  <h2>Tabela por filial</h2>
  <div class="table-scroll">
    <table class="table-wide">
      <thead>
        <tr>
          <th>Filial</th>
          {% for month in month_labels %}
          <th class="month">{{ month }}</th>
          {% endfor %}
        </tr>
      </thead>
      <tbody>
        {% for group in series_groups %}
        <tr>
          <td>{{ group.name }}</td>
          {% for row in group.series %}
          <td class="num">{{ row.formatted or row.value or "—" }}</td>
          {% endfor %}
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>

<section>
  <h2>Ranking no ano</h2>
  <p class="chart-caption">Total acumulado Jan–Dez por filial — comparação direta, eixo a partir de zero.</p>
  <div class="chart-container chart-container--ranking" style="--ranking-rows: {{ ranking_labels | length }};">
    <canvas id="ranking-chart"></canvas>
  </div>
</section>

<section>
  <h2>Evolução mensal</h2>
  {% if trend_note %}
  <p class="chart-caption">{{ trend_note }}</p>
  {% endif %}
  <div class="chart-container chart-container--trend">
    <canvas id="trend-chart"></canvas>
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
(function () {
  const isPercent = {{ is_percent | tojson }};
  const monthLabels = {{ chart_labels | tojson }};
  const rankingLabels = {{ ranking_labels | tojson }};
  const rankingValues = {{ ranking_values | tojson }};
  const rankingColors = {{ ranking_colors | tojson }};
  const trendDatasets = {{ trend_datasets | tojson }};

  function formatValue(value) {
    if (value == null || Number.isNaN(value)) return "—";
    if (isPercent) return value.toLocaleString("pt-BR", { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + "%";
    return value.toLocaleString("pt-BR", { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  const valueTick = (value) => formatValue(value);
  const tooltipLabel = (context) => {
    const label = context.dataset.label || "";
    const value = context.parsed.y ?? context.parsed.x;
    return `${label}: ${formatValue(value)}`;
  };

  const rankingCtx = document.getElementById("ranking-chart");
  if (rankingCtx && rankingLabels.length) {
    new Chart(rankingCtx, {
      type: "bar",
      data: {
        labels: rankingLabels,
        datasets: [{
          label: "Total no ano",
          data: rankingValues,
          backgroundColor: rankingColors,
          borderColor: rankingColors,
          borderWidth: 1,
          borderRadius: 6,
          barThickness: 22,
        }],
      },
      options: {
        indexAxis: "y",
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: { callbacks: { label: tooltipLabel } },
        },
        scales: {
          x: {
            beginAtZero: true,
            ticks: { callback: valueTick },
            grid: { color: "rgba(148, 163, 184, 0.25)" },
          },
          y: {
            grid: { display: false },
          },
        },
      },
    });
  }

  const trendCtx = document.getElementById("trend-chart");
  if (trendCtx && monthLabels.length && trendDatasets.length) {
    new Chart(trendCtx, {
      type: "line",
      data: { labels: monthLabels, datasets: trendDatasets },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: "index", intersect: false },
        plugins: {
          legend: { position: "bottom", labels: { boxWidth: 12, padding: 16 } },
          tooltip: { callbacks: { label: tooltipLabel } },
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: { callback: valueTick },
            grid: { color: "rgba(148, 163, 184, 0.25)" },
          },
          x: {
            grid: { display: false },
          },
        },
      },
    });
  }
})();
</script>
