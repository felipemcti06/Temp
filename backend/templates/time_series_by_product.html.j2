<header class="report-header">
  {% if logo_src %}
  <img class="report-logo" src="{{ logo_src }}" alt="{{ brand_name }}" />
  {% endif %}
  <div class="report-header__text">
    <p class="report-brand">{{ brand_name }} · Relatório Gerencial</p>
    <p class="report-meta">
      {{ metric }} · {{ period }} · Por produto · Versão {{ version }} · Gerado em {{ generated_at }}
    </p>
  </div>
</header>

<h1>{{ title }}</h1>

<section>
  <h2>Resumo executivo</h2>
  <p>{{ summary }}</p>
</section>

<section class="report-table-section">
  <h2>Tabela por produto</h2>
  <div class="table-scroll">
    <table class="table-wide">
      <thead>
        <tr>
          <th>Produto</th>
          {% for month in month_labels %}
          <th class="month">{{ month }}</th>
          {% endfor %}
        </tr>
      </thead>
      <tbody>
        {% for group in series_groups %}
        <tr>
          <td>{{ group.name }}</td>
          {% for row in group.series %}
          <td class="num">{{ row.formatted or row.value or "—" }}</td>
          {% endfor %}
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>

<section>
  <h2>Gráfico comparativo</h2>
  <div class="chart-container chart-container--tall">
    <canvas id="chart"></canvas>
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
(function () {
  const labels = {{ chart_labels | tojson }};
  const datasets = {{ chart_datasets | tojson }};
  const ctx = document.getElementById("chart");
  if (!ctx || !labels.length || !datasets.length) return;

  new Chart(ctx, {
    type: "line",
    data: { labels, datasets },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      aspectRatio: 2.4,
      plugins: { legend: { position: "bottom" } },
      scales: { y: { beginAtZero: false } }
    }
  });
})();
</script>
